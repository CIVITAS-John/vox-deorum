{
  "name": "vox-agents",
  "version": "1.0.0",
  "description": "LLM-powered strategic AI agents for Civilization V that provide high-level decision making and strategy planning through the Vox Deorum system.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node ../node_modules/typescript/bin/tsc && cd ui && npm run build",
    "dev": "tsx watch --import ./src/instrumentation.ts src/index.ts",
    "start": "npm run build && npm run start:dist --",
    "start:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/index.js",
    "strategist": "npm run build && npm run strategist:dist --",
    "strategist:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/strategist/index.js",
    "telepathist": "npm run build && npm run telepathist:dist --",
    "telepathist:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/telepathist/console.js",
    "oracle": "npm run build && npm run oracle:dist --",
    "oracle:dist": "node --inspect --import ./dist/instrumentation.js --experimental-loader=@opentelemetry/instrumentation/hook.mjs dist/oracle/index.js",
    "test": "vitest run --exclude tests/infra/**",
    "test:watch": "vitest --exclude tests/infra/**",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --exclude tests/infra/**",
    "test:unit": "vitest run --exclude tests/infra/**",
    "test:game": "vitest run tests/infra",
    "archivist": "npm run build && npm run archivist:dist --",
    "archivist:dist": "node --import ./dist/instrumentation.js dist/archivist/index.js",
    "type-check": "tsc --noEmit",
    "docs": "typedoc"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "open": "^11.0.0",
    "uuid": "^13.0.0"
  }
}
